# 온고지식 모바일 앱 환경변수 예시
# 이 파일을 복사하여 .env 로 저장 후 값을 채워주세요.

# 백엔드 API 서버 주소
EXPO_PUBLIC_API_BASE_URL=https://your-api-server.com

# 로그인 전 임시 JWT 토큰 (개발용)
EXPO_PUBLIC_API_TEMP_TOKEN=

# 구글 로그인 클라이언트 설정
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_URL_SCHEME=

# VWorld API 키
EXPO_PUBLIC_VWORLD_API_KEY=

# Google Cloud Translation API 키
EXPO_PUBLIC_GOOGLE_TRANSLATION_API_KEY=

# pnpm 모노레포에서 로컬 Android 빌드 시 필수
# Metro가 워크스페이스 루트 대신 apps/mobile을 서버 루트로 사용하도록 설정
# 없으면 "Unable to resolve module ./index.js from C:\ongo\client/." 에러 발생
EXPO_NO_METRO_WORKSPACE_ROOT=1
